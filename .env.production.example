# Production example for the first Docker rollout.
# Copy this file to `../shared/env/production.env` on the host.
# This rollout is file-mode only: do not add DATABASE_URL here.

NAV_STORAGE_MODE="file"
AUTH_SECRET="replace-with-long-random-string"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="replace-me"
NEXTAUTH_URL="https://example.com"
JOB_RUNNER_SECRET="replace-with-long-random-string"
