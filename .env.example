# General/local example for development and non-Docker workflows.
# For the first Docker/server rollout, copy `.env.production.example` to
# `../shared/env/production.env` on the host and keep production secrets there.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nav_website?schema=public"

# Local/file-mode defaults
NAV_STORAGE_MODE="file"
AUTH_SECRET="replace-this-with-a-long-random-string"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
NEXTAUTH_URL="http://localhost:3000"
JOB_RUNNER_SECRET="replace-this-for-cron-runner"
TASK_RUNNER_BATCH_LIMIT="8"
TASK_RUNNER_RETRY_BACKOFF_MS="30000"
